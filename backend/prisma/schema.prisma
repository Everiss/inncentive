generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model addresses {
  id           Int       @id @default(autoincrement())
  company_id   Int
  street       String?   @db.VarChar(255)
  number       String?   @db.VarChar(50)
  complement   String?   @db.VarChar(255)
  neighborhood String?   @db.VarChar(100)
  city         String?   @db.VarChar(100)
  state        String?   @db.Char(2)
  zip_code     String?   @db.VarChar(10)
  companies    companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "addresses_ibfk_1")

  @@index([company_id], map: "company_id")
}

model cnaes {
  code          String          @id @db.VarChar(20)
  description   String          @db.Text
  company_cnaes company_cnaes[]
}

model companies {
  id                         Int                          @id @default(autoincrement())
  cnpj                       String                       @unique(map: "cnpj") @db.VarChar(20)
  legal_name                 String                       @db.VarChar(255)
  trade_name                 String?                      @db.VarChar(255)
  open_date                  DateTime?                    @db.Date
  legal_nature               String?                      @db.VarChar(255)
  porte                      String?                      @db.VarChar(100)
  capital_social             Decimal?                     @db.Decimal(15, 2)
  situation                  String?                      @db.VarChar(50)
  situation_reason           String?                      @db.Text
  situation_date             DateTime?                    @db.Date
  email                      String?                      @db.VarChar(255)
  status                     String?                      @db.VarChar(50)
  updated_at                 DateTime?                    @db.DateTime(0)
  created_at                 DateTime?                    @default(now()) @db.Timestamp(0)
  addresses                  addresses[]
  company_cnaes              company_cnaes[]
  company_fiscal_year_config company_fiscal_year_config[]
  company_obligations        company_obligations[]
  company_partners           company_partners[]
  phones                     company_phones[]
  contact_companies          contact_companies[]
  dirbi_monthly_records      dirbi_monthly_records[]
  ecf_lalur_entries          ecf_lalur_entries[]
  formpd_forms               formpd_forms[]
  payroll_import_jobs        payroll_import_jobs[]
  payroll_import_templates   payroll_import_templates[]
  payroll_rubric_catalog     payroll_rubric_catalog[]
  payroll_rubric_maps        payroll_rubric_maps[]
  payroll_sheets             payroll_sheets[]
  rdi_assets                 rdi_assets[]
  rdi_expense_documents      rdi_expense_documents[]
  rdi_hr_timesheets          rdi_hr_timesheets[]
  rdi_overhead_rates         rdi_overhead_rates[]
  rdi_projects               rdi_projects[]
  rdi_timesheet_entries      rdi_timesheet_entries[]
  tax_regregimes             tax_regregimes[]
  user_company_access        user_company_access[]
  ia_executions              ia_executions[]
}

model company_cnaes {
  company_id Int
  cnae_code  String    @db.VarChar(20)
  is_primary Boolean?  @default(false)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "company_cnaes_ibfk_1")
  cnaes      cnaes     @relation(fields: [cnae_code], references: [code], onDelete: Cascade, onUpdate: NoAction, map: "company_cnaes_ibfk_2")

  @@id([company_id, cnae_code])
  @@index([cnae_code], map: "cnae_code")
}

model company_partners {
  id                      Int       @id @default(autoincrement())
  company_id              Int
  partner_id              Int
  qualification           String?   @db.VarChar(255)
  legal_rep_name          String?   @db.VarChar(255)
  legal_rep_qualification String?   @db.VarChar(255)
  companies               companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "company_partners_ibfk_1")
  partners                partners  @relation(fields: [partner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "company_partners_ibfk_2")

  @@index([company_id], map: "company_id")
  @@index([partner_id], map: "partner_id")
}

model partners {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  country_origin   String?            @db.VarChar(100)
  company_partners company_partners[]

  @@unique([name, country_origin], map: "name")
}

model tax_regregimes {
  id           Int                 @id @default(autoincrement())
  company_id   Int
  type         tax_regregimes_type
  is_optant    Boolean?            @default(false)
  opt_in_date  DateTime?           @db.Date
  opt_out_date DateTime?           @db.Date
  updated_at   DateTime?           @db.DateTime(0)
  companies    companies           @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tax_regregimes_ibfk_1")

  @@index([company_id], map: "company_id")
}

model import_batches {
  id                Int            @id @default(autoincrement())
  entity_type       String         @db.VarChar(50)
  file_name         String         @db.VarChar(255)
  status            String         @default("PENDING") @db.VarChar(50)
  total_records     Int            @default(0)
  processed_records Int            @default(0)
  success_count     Int            @default(0)
  error_count       Int            @default(0)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @default(now()) @updatedAt
  items             import_items[]
}

model import_items {
  id            Int            @id @default(autoincrement())
  batch_id      Int
  record_data   String         @db.Text
  status        String         @default("PENDING") @db.VarChar(50)
  error_message String?        @db.Text
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  batch         import_batches @relation(fields: [batch_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_import_items_batch")

  @@index([batch_id], map: "fk_import_items_batch")
}

/// Central person entity. All collaborators and users MUST have a contacts record first.
model contacts {
  id                                                            Int                                @id @default(autoincrement())
  name                                                          String                             @db.VarChar(255)
  email                                                         String?                            @unique
  cpf                                                           String?                            @unique @db.VarChar(14)
  avatar_url                                                    String?                            @db.VarChar(500)
  created_at                                                    DateTime                           @default(now()) @db.Timestamp(0)
  updated_at                                                    DateTime                           @default(now()) @updatedAt @db.DateTime(0)
  collaborator                                                  collaborators?
  contact_companies                                             contact_companies[]
  phones                                                        contact_phones[]
  formpd_form_representatives                                   formpd_form_representatives[]
  formpd_opinions                                               formpd_opinions[]
  formpd_project_human_resources                                formpd_project_human_resources[]
  payroll_import_jobs_payroll_import_jobs_created_byTocontacts  payroll_import_jobs[]              @relation("payroll_import_jobs_created_byTocontacts")
  payroll_import_jobs_payroll_import_jobs_promoted_byTocontacts payroll_import_jobs[]              @relation("payroll_import_jobs_promoted_byTocontacts")
  payroll_import_template_versions                              payroll_import_template_versions[]
  payroll_rubric_catalog                                        payroll_rubric_catalog[]
  payroll_rubric_maps                                           payroll_rubric_maps[]
  payroll_sheet_items                                           payroll_sheet_items[]
  payroll_sheets_payroll_sheets_approved_byTocontacts           payroll_sheets[]                   @relation("payroll_sheets_approved_byTocontacts")
  payroll_sheets_payroll_sheets_imported_byTocontacts           payroll_sheets[]                   @relation("payroll_sheets_imported_byTocontacts")
  rdi_expense_allocations                                       rdi_expense_allocations[]
  rdi_expense_documents                                         rdi_expense_documents[]
  rdi_hr_allocations_rdi_hr_allocations_contact_idTocontacts    rdi_hr_allocations[]               @relation("rdi_hr_allocations_contact_idTocontacts")
  rdi_hr_allocations_rdi_hr_allocations_reviewed_byTocontacts   rdi_hr_allocations[]               @relation("rdi_hr_allocations_reviewed_byTocontacts")
  rdi_hr_timesheets_rdi_hr_timesheets_approved_byTocontacts     rdi_hr_timesheets[]                @relation("rdi_hr_timesheets_approved_byTocontacts")
  rdi_hr_timesheets_rdi_hr_timesheets_contact_idTocontacts      rdi_hr_timesheets[]                @relation("rdi_hr_timesheets_contact_idTocontacts")
  rdi_overhead_rates                                            rdi_overhead_rates[]
  rdi_project_annual_snapshots                                  rdi_project_annual_snapshots[]
  rdi_project_documents                                         rdi_project_documents[]
  rdi_projects                                                  rdi_projects[]
  rdi_timesheet_entries                                         rdi_timesheet_entries[]
  user                                                          users?
  ia_task_configs                                               ia_task_configs[]
  ia_prompts                                                    ia_prompts[]
}

/// A contact can be linked to many companies, with a different role per link.
model contact_companies {
  id         Int       @id @default(autoincrement())
  contact_id Int
  company_id Int
  role       String    @default("COMUM") @db.VarChar(20)
  notes      String?   @db.Text
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  company    companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cc_company")
  contact    contacts  @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cc_contact")

  @@index([company_id])
  @@index([contact_id])
  @@index([contact_id, company_id, role])
}

/// Optional 1:1 extension for contacts who are employees/collaborators.
model collaborators {
  id                          Int                           @id @default(autoincrement())
  contact_id                  Int                           @unique
  position                    String?                       @db.VarChar(255)
  department                  String?                       @db.VarChar(255)
  admission_date              DateTime?                     @db.Date
  termination_date            DateTime?                     @db.Date
  registration_number         String?                       @db.VarChar(50)
  observations                String?                       @db.Text
  is_active                   Boolean                       @default(true)
  employment_type             collaborators_employment_type @default(CLT)
  academic_degree             collaborators_academic_degree @default(NAO_INFORMADO)
  is_researcher               Boolean                       @default(false)
  created_at                  DateTime                      @default(now()) @db.Timestamp(0)
  updated_at                  DateTime                      @default(now()) @updatedAt @db.DateTime(0)
  contact                     contacts                      @relation(fields: [contact_id], references: [id], onUpdate: NoAction, map: "fk_collab_contact")
  payroll_import_staging_rows payroll_import_staging_rows[]
  payroll_sheets              payroll_sheets[]
}

/// Optional 1:1 extension for contacts with system access.
/// Login email = contacts.email — no duplication.
model users {
  id                                                        Int                   @id @default(autoincrement())
  contact_id                                                Int                   @unique
  password_hash                                             String                @db.VarChar(255)
  system_role                                               system_role           @default(VIEWER)
  is_active                                                 Boolean               @default(true)
  last_login                                                DateTime?             @db.DateTime(0)
  created_at                                                DateTime              @default(now()) @db.Timestamp(0)
  updated_at                                                DateTime              @default(now()) @updatedAt @db.DateTime(0)
  user_company_access_user_company_access_granted_byTousers user_company_access[] @relation("user_company_access_granted_byTousers")
  user_company_access_user_company_access_user_idTousers    user_company_access[] @relation("user_company_access_user_idTousers")
  contact                                                   contacts              @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_contact")
}

/// One contact can have many phones with different types.
model contact_phones {
  id         Int        @id @default(autoincrement())
  contact_id Int
  number     String     @db.VarChar(30)
  type       phone_type @default(CELULAR)
  is_primary Boolean    @default(false)
  created_at DateTime   @default(now()) @db.Timestamp(0)
  updated_at DateTime   @default(now()) @updatedAt @db.DateTime(0)
  contact    contacts   @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cont_phones_contact")

  @@index([contact_id])
}

/// One company can have many phones with different types.
model company_phones {
  id         Int        @id @default(autoincrement())
  company_id Int
  number     String     @db.VarChar(30)
  type       phone_type @default(FIXO)
  is_primary Boolean    @default(false)
  created_at DateTime   @default(now()) @db.Timestamp(0)
  updated_at DateTime   @default(now()) @updatedAt @db.DateTime(0)
  company    companies  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comp_phones_company")

  @@index([company_id])
}

